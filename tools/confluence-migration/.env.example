# Confluence Cloud (or Server) credentials
# Get API token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_USERNAME=you@example.com
CONFLUENCE_API_TOKEN=your_api_token_here

# Arkon instance (the running Master Design Vault)
# Use an admin/editor account that has the `doc:create` permission
ARKON_URL=http://localhost:8000
ARKON_EMAIL=admin@bank.local
ARKON_PASSWORD=change_me
