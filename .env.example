# ============================================================
# Arkon — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://arkon:arkon_secret@localhost:5432/arkon

# --- Auth (JWT) ---
# Used to sign JWT tokens. Generate a strong random string:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-secret-string

# --- Default Admin Account ---
# Created automatically on first startup if no admin exists.
# Change the password in Admin Portal after first login.
DEFAULT_ADMIN_EMAIL=admin@arkon.local
DEFAULT_ADMIN_PASSWORD=admin123

# --- MinIO (S3-compatible storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret
MINIO_BUCKET=arkon-files
MINIO_SECURE=false
MINIO_PRESIGN_EXPIRY_HOURS=24

# --- Neo4j (Knowledge Graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
ENABLE_ENTITY_EXTRACTION=false

# --- Redis (Background worker queue) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
WORKER_MAX_JOBS=3
WORKER_JOB_TIMEOUT=600

# --- Chunking ---
CHUNK_SIZE=1500
CHUNK_OVERLAP=150

# --- CORS ---
CORS_ORIGINS=*

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:5055

# ============================================================
# AI provider settings (embedding, LLM, vision) are configured
# through the Admin Portal > Settings, NOT in this file.
# ============================================================
